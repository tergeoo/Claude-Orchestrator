# Agent environment variables
# ─────────────────────────────────────────────────────────────────────────────
# For local dev:   copy to agent/.env  →  make agent
# For production:  copy values into the launchd plist EnvironmentVariables
# ─────────────────────────────────────────────────────────────────────────────

# Stable unique identifier for this agent.
# Generate once: uuidgen | tr A-Z a-z
AGENT_ID=

# Display name shown in the iOS app (default: hostname).
AGENT_NAME=My Mac

# Pre-shared secret that must match AGENT_SECRET in relay/.env.
AGENT_SECRET=your-agent-secret

# Relay WebSocket URL.
# Local network: ws://192.168.x.x:8080
# Cloud:         wss://your-relay.up.railway.app
RELAY_URL=ws://192.168.1.10:8080

# Command to launch in new terminal sessions.
DEFAULT_COMMAND=claude
